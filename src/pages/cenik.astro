---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/Container.astro";
import SectionMarker from "../components/SectionMarker.astro";
import Button from "../components/Button.astro";

const HOURLY_RATE = "1 000";

const title = "Ceník · Connexus";
const description = `Hodinová sazba ${HOURLY_RATE} Kč/hod a typické rozsahy projektů. Po spuštění tarify od 800 do 5 000 Kč/měsíc, nebo žádný plán. Bez smlouvy na rok, bez skrytých položek.`;

interface Tier {
  name: string;
  price: string;
  tagline: string;
  outcome?: string;
  bullets: string[];
  highlighted?: boolean;
}

const tiers: Tier[] = [
  {
    name: "Žádný plán",
    price: `${HOURLY_RATE} Kč/hod`,
    tagline: "Bez měsíční platby. Ozvete se, jen když něco potřebujete.",
    bullets: [
      "Ad-hoc zásahy podle potřeby",
      "Vyúčtování po hodině",
      "Odpověď do 5 pracovních dní",
      "Bez smlouvy",
    ],
  },
  {
    name: "Údržba",
    price: "800 Kč/měsíc",
    tagline: "Pro klienty, kteří si web spravují sami a chtějí mě po ruce.",
    bullets: [
      "Drobné úpravy webu (do 1 hodiny měsíčně)",
      "Technický monitoring (formuláře, výpadky, chyby)",
      "Odpověď do 3 pracovních dní",
      "Bez článků a aktivního marketingu, to řeší Growth",
    ],
  },
  {
    name: "Growth",
    price: "5 000 Kč/měsíc",
    highlighted: true,
    tagline: "Aby vás Google začal víc nacházet, a vy věděli proč.",
    outcome:
      "Po šesti měsících typicky vidíte měřitelný posun v lokálním vyhledávání a jasná data, kde web ztrácí pozornost a co s tím dál.",
    bullets: [
      "1 SEO článek měsíčně (~1 200 slov, ručně psaný, cílený na konkrétní klíčové slovo)",
      "Drobné úpravy webu, texty, obrázky, změny (do 2 hodin měsíčně)",
      "Měsíční post na Google profilu + reakce na všechny nové recenze do 3 prac. dní",
      "4× ročně audit chování návštěvníků: kam klikají, kde odpadávají, co opravit",
      "Měsíční report na 1 stránku: kolik lidí přišlo, odkud, kdo se ozval, co dál",
      "Odpověď do 2 pracovních dní",
    ],
  },
];

const includedItems = [
  "Vlastní design a kompletní web",
  "Texty pro všechny stránky podle vašeho byznysu",
  "Aby vás Google začal nacházet (SEO)",
  "Měření, kdo přišel a co je zajímalo (analytika)",
  "Založení nebo optimalizace Google firemního profilu",
];

interface Faq {
  question: string;
  answer: string;
}

const faqs: Faq[] = [
  {
    question: "V čem je rozdíl proti šabloně z internetu?",
    answer:
      "Šablonový web vás dostane online a tím to končí. U mě kupujete strategii, vlastní design, texty psané podle vašeho byznysu a SEO, které šablona nemá. Šablonu si dokáže každý splácat sám za týden, výsledek je plichta s tisíci dalšími. Tohle je <strong>rozdíl mezi vizitkou a nástrojem</strong>, který lidem dává důvod ozvat se právě vám.",
  },
  {
    question: "Jak rychle uvidím, že to funguje?",
    answer:
      "První přímé reakce vidíte typicky v týdnech po spuštění. Strategický web přesvědčí lidi, kteří už o vás slyšeli z doporučení, takže se začnou ozývat hned. Organická viditelnost v Googlu narůstá pomaleji: <strong>tři až pět měsíců na konkrétnější dotazy, déle na obecnější</strong>. Proto doporučuju tarif Growth alespoň na prvních šest měsíců. Pravidelné články a optimalizace na datech jsou to, co posun reálně přinese.",
  },
  {
    question: "Co když budu chtít přestat?",
    answer:
      "Žádný problém. Doména je registrovaná na vaše jméno, Google firemní profil pod vámi, do analytiky máte plný přístup, zdrojový kód webu vám předám. Můžete ho přesunout na libovolný hosting. Žádná smlouva na rok, žádný výpovědní rituál. Mezi tarify se dá kdykoli přejít, nahoru i dolů, a kdykoli odejít úplně.",
  },
  {
    question: "Můžu platit ve splátkách?",
    answer:
      "Ano. Jakmile po prvním hovoru odhadneme rozsah, rozdělíme platbu standardně na tři milníky: <strong>40 % při podpisu, 30 % při schválení designu, 30 % při spuštění</strong>. Pokud máte jiný rytmus cash-flow, domluvíme individuální plán. Stačí říct předem.",
  },
  {
    question: "S kým pracujete?",
    answer:
      "Se solo podnikateli a malými studii v jakémkoli expertním oboru postaveném na důvěře a doporučeních: poradci, řemeslníci, terapeuti, advokáti, kouči, drobné firmy. Strategický web funguje stejně, ať jde o jakoukoli profesi, kde si lidi nejdřív ověřují, kdo jste, než se vám ozvou.",
  },
  {
    question: "Jak dlouho to celé trvá?",
    answer:
      "Záleží na rozsahu. <strong>Menší prezentace typicky 2–3 týdny</strong>: krátká strategie, design a stavba v jednom sledu. <strong>Plnohodnotný strategický web 5–6 týdnů</strong>: týden 1–2 strategie, týden 3–6 stavba, pak web jde živě. Po spuštění následuje postlaunch ladění a podle zvoleného tarifu pokračující péče.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Vlastní web, SEO a péče po spuštění",
  description:
    "Kompletní webová prezentace včetně strategie, designu, textů, SEO a péče po spuštění. Pro solo podnikatele a malá studia.",
  provider: {
    "@id": "https://connexus.cz/#connexus",
  },
  areaServed: {
    "@type": "Country",
    name: "Česká republika",
  },
  offers: {
    "@type": "Offer",
    priceSpecification: {
      "@type": "UnitPriceSpecification",
      price: "1000",
      priceCurrency: "CZK",
      unitCode: "HUR",
      unitText: "hodina",
    },
    description:
      "Hodinová sazba 1 000 Kč. Menší prezentace typicky 15–25 tis. Kč, plnohodnotný strategický web 35–60 tis. Kč podle rozsahu. Splátky individuálně.",
  },
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(serviceSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(faqSchema)}
    />
  </Fragment>

  <Nav />

  <main id="main">
    <Container class="pt-32 md:pt-40">
      <a
        href="/"
        class="inline-flex items-center gap-2 font-mono text-small text-text-muted transition-colors hover:text-text-primary"
      >
        ← Zpět na úvod
      </a>
    </Container>

    <section class="pb-12 pt-10 md:pb-20 md:pt-14">
      <Container>
        <div class="max-w-[900px] space-y-8 md:space-y-10">
          <p class="font-mono text-small uppercase tracking-[0.08em] text-accent">
            Ceník
          </p>

          <h1 class="font-serif text-display-sm font-medium leading-[1.05] tracking-tight text-text-primary md:text-display">
            Ceník
          </h1>

          <p class="max-w-prose text-body-lg text-text-secondary">
            <strong class="text-text-primary">Sazbu ukazuju rovnou.</strong>
            Pokud dává smysl, povíme si o vašem byznysu. Pokud ne, ušetřili
            jsme oba čas.
          </p>
        </div>
      </Container>
    </section>

    <section class="py-20 md:py-32" aria-labelledby="sazba">
      <Container>
        <SectionMarker number="01" label="Sazba a rozsah" />

        <h2 id="sazba" class="sr-only">Sazba a rozsah</h2>

        <div class="mt-10 grid gap-10 md:mt-14 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-7">
            <p class="font-mono text-small uppercase tracking-[0.08em] text-text-muted">
              Hodinová sazba
            </p>
            <p class="cenik-price mt-3 font-serif font-medium text-text-primary md:mt-4">
              {HOURLY_RATE} <span class="cenik-price-unit">Kč/hod</span>
            </p>
            <p class="mt-6 max-w-prose text-body-lg text-text-secondary md:mt-8">
              <strong class="text-text-primary"
                >Menší prezentace typicky 15–25 tis. Kč.</strong
              > Plnohodnotný strategický web s vlastními texty a SEO obvykle
              35–60 tis. Kč podle rozsahu. Přesnou cenu řekneme po prvním
              hovoru, bez závazku.
            </p>
            <p class="mt-6 max-w-prose text-body text-text-secondary">
              Splátky standardně 40 / 30 / 30: při podpisu, při schválení
              designu, při spuštění. Jiný rytmus cash-flow domluvíme
              individuálně.
            </p>
          </div>

          <div class="md:col-span-5">
            <p class="font-mono text-small uppercase tracking-[0.08em] text-text-muted">
              Co je v projektu
            </p>
            <ul class="mt-5 space-y-3 text-body text-text-secondary">
              {
                includedItems.map((item) => (
                  <li class="flex gap-3">
                    <span class="text-border-strong" aria-hidden="true">
                      —
                    </span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </Container>
    </section>

    <section
      class="bg-bg-secondary py-20 md:py-32"
      aria-labelledby="dlouhodoba"
    >
      <Container>
        <SectionMarker number="02" label="Po spuštění" />

        <div class="mt-10 grid gap-10 md:mt-14 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-7">
            <h2
              id="dlouhodoba"
              class="font-serif text-h2-sm font-medium md:text-h2"
            >
              Co po spuštění.
            </h2>
          </div>
          <div class="md:col-span-5">
            <p class="max-w-prose text-body text-text-secondary">
              Vyberete si, jak chcete pokračovat. Mezi tarify se dá kdykoli
              přejít, nahoru i dolů.
              <strong class="text-text-primary">Bez smlouvy na rok.</strong>
            </p>
          </div>
        </div>

        <div class="mt-14 border-t border-border-subtle md:mt-20">
          {
            tiers.map((tier) => (
              <article class="grid gap-6 border-b border-border-subtle py-10 md:grid-cols-12 md:gap-12 md:py-14">
                <div class="md:col-span-4">
                  {tier.highlighted && (
                    <p class="font-mono text-small uppercase tracking-[0.08em] text-accent">
                      Nejčastější volba
                    </p>
                  )}
                  <h3
                    class:list={[
                      "font-serif text-h2-sm font-medium text-text-primary md:text-h2",
                      tier.highlighted ? "mt-3" : "",
                    ]}
                  >
                    {tier.name}
                  </h3>
                  <p class="mt-3 font-mono text-body text-text-secondary md:mt-4">
                    {tier.price}
                  </p>
                </div>
                <div class="md:col-span-8 md:pt-2">
                  <p class="max-w-prose text-body-lg text-text-primary">
                    {tier.tagline}
                  </p>
                  {tier.outcome && (
                    <p class="mt-3 max-w-prose text-body text-text-secondary md:mt-4">
                      {tier.outcome}
                    </p>
                  )}
                  <ul class="mt-6 space-y-3 text-body text-text-secondary md:mt-8">
                    {tier.bullets.map((bullet) => (
                      <li class="flex gap-3">
                        <span class="text-border-strong" aria-hidden="true">
                          —
                        </span>
                        <span>{bullet}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </Container>
    </section>

    <section class="py-20 md:py-32" aria-labelledby="faq">
      <Container>
        <SectionMarker number="03" label="Časté otázky" />

        <div class="mt-10 grid gap-10 md:mt-14 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-4">
            <h2
              id="faq"
              class="font-serif text-h2-sm font-medium md:text-h2"
            >
              Na co se nejčastěji ptají.
            </h2>
          </div>
          <div class="md:col-span-8">
            <div class="border-t border-border-subtle">
              {
                faqs.map((faq) => (
                  <details class="faq-item border-b border-border-subtle">
                    <summary class="faq-summary flex cursor-pointer items-start justify-between gap-6 py-6 md:py-8">
                      <span class="font-serif text-h3-sm font-medium text-text-primary md:text-h3">
                        {faq.question}
                      </span>
                      <span
                        class="faq-icon mt-2 shrink-0 font-mono text-body text-text-muted md:mt-3"
                        aria-hidden="true"
                      ></span>
                    </summary>
                    <div class="faq-answer pb-6 md:pb-8">
                      <p
                        class="max-w-prose text-body text-text-secondary"
                        set:html={faq.answer}
                      />
                    </div>
                  </details>
                ))
              }
            </div>
          </div>
        </div>
      </Container>
    </section>

    <section
      class="bg-bg-secondary py-16 md:py-20"
      aria-labelledby="dalsi-krok"
    >
      <Container>
        <h2 id="dalsi-krok" class="sr-only">Další krok</h2>
        <div
          class="flex flex-col gap-5 sm:flex-row sm:items-center sm:gap-8"
        >
          <Button href="/#kontakt" variant="primary">Domluvit konzultaci</Button>
        </div>
      </Container>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .cenik-price {
    font-size: clamp(56px, 10vw, 112px);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .cenik-price-unit {
    font-size: 0.45em;
    color: theme("colors.text.secondary");
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .faq-item > summary {
    list-style: none;
  }
  .faq-item > summary::-webkit-details-marker {
    display: none;
  }
  .faq-icon {
    display: inline-block;
    min-width: 1ch;
    text-align: center;
    transition: color 200ms ease;
  }
  .faq-icon::before {
    content: "+";
  }
  .faq-item[open] .faq-icon::before {
    content: "−";
  }
  .faq-answer {
    animation: faq-fade-in 250ms ease-out;
  }
  @media (prefers-reduced-motion: reduce) {
    .faq-icon,
    .faq-answer {
      animation: none;
      transition: none;
    }
  }
  @keyframes faq-fade-in {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .faq-summary:hover .faq-icon {
    color: theme("colors.text.primary");
  }
</style>
