---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/Container.astro";
import SectionMarker from "../components/SectionMarker.astro";
import Button from "../components/Button.astro";

const title = "Časté otázky · Connexus";
const description =
  "Cena se odvíjí od konkrétního zadání. Odpovědi na nejčastější otázky o spolupráci, rozsahu a tom, co se děje po spuštění webu.";

interface Faq {
  question: string;
  answer: string;
}

const faqs: Faq[] = [
  {
    question: "Kolik web stojí?",
    answer:
      "Cena se vždy odvíjí od konkrétního zadání a vašeho byznysu. Po krátkém úvodním hovoru posílám písemný odhad rozsahu, ceny a časového rámce. <strong>Bez závazku, bez balíčků na rok</strong>.",
  },
  {
    question: "V čem je rozdíl proti šabloně z internetu?",
    answer:
      "Šablona dostane online vás i osmdesát dalších v oboru. U mě kupujete vlastní strategii, vlastní design a texty psané pro vaši konkrétní klientelu, ne pro generického „majitele firmy\". Šablona je vizitka; <strong>tohle je nástroj, který lidem dává důvod ozvat se právě vám</strong>.",
  },
  {
    question: "Jak rychle uvidím, že to funguje?",
    answer:
      "Konverze z přímé návštěvnosti — reklama, doporučení, sociální sítě — uvidíte hned po spuštění. Buď roste, nebo neroste. SEO trvá <strong>tři až devět měsíců</strong> podle oboru a konkurence; pokud vám někdo slibuje rychlejší výsledky v Googlu, lže. Data po 30 dnech vyhodnotíme a směr ladíme.",
  },
  {
    question: "Co se děje po spuštění?",
    answer:
      "<strong>30 dnů post-launch ladění je v ceně</strong> — drobné úpravy, oprava chyb, dolad textů podle prvních dat. Pokud chcete pokračovat, nabízím pravidelnou péči (drobné úpravy, články, optimalizace, péče o Google profil, měsíční report), ad-hoc zásahy bez závazku, nebo úplné předání. Rozsah a rytmus si určujete vy.",
  },
  {
    question: "Co když budu chtít přestat?",
    answer:
      "Doména je registrovaná na vaše jméno. Google firemní profil pod vámi. Do analytiky máte plný přístup. Zdrojový kód předám. Můžete web kdykoli přesunout na libovolný hosting. <strong>Žádná smlouva na rok, žádný výpovědní rituál</strong> — to jsou techniky agentur, které doufají, že odejít je víc práce než zůstat.",
  },
  {
    question: "Můžu platit ve splátkách?",
    answer: "Ano.",
  },
  {
    question: "Jak dlouho to celé trvá?",
    answer:
      "Tři až šest týdnů podle rozsahu a vaší dostupnosti. Týden 1–2 strategie a design, týden 3–5 stavba, závěr revize a spuštění. Po spuštění je <strong>30 dnů post-launch ladění zahrnuto</strong>. Klienti, kteří odpovídají rychle, jdou živě za tři týdny; klienti, kteří mizí na týden, jdou za šest. Není to mystika, je to o tempu.",
  },
  {
    question: "S kým pracujete?",
    answer:
      "Se solo profesionály a malými studii v Česku, kteří chtějí vlastní web místo šablony.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(faqSchema)}
    />
  </Fragment>

  <Nav />

  <main id="main">
    <Container class="pt-32 md:pt-40">
      <a
        href="/"
        class="inline-flex items-center gap-2 font-mono text-small text-text-muted transition-colors hover:text-text-primary"
      >
        ← Zpět na úvod
      </a>
    </Container>

    <section class="pb-12 pt-10 md:pb-20 md:pt-14">
      <Container>
        <div class="max-w-[900px] space-y-8 md:space-y-10">
          <p class="font-mono text-small uppercase tracking-[0.08em] text-accent">
            Časté otázky
          </p>

          <h1 class="font-serif text-display-sm font-medium leading-[1.05] tracking-tight text-text-primary md:text-display">
            Časté otázky.
          </h1>

          <p class="max-w-prose text-body-lg text-text-secondary">
            Cena se vždy odvíjí od konkrétního zadání a vašeho byznysu. Po
            krátkém úvodním hovoru posílám písemný odhad rozsahu, ceny
            a časového rámce.
            <strong class="text-text-primary"
              >Bez závazku, bez balíčků na rok.</strong
            >
          </p>
        </div>
      </Container>
    </section>

    <section class="py-20 md:py-32" aria-labelledby="faq">
      <Container>
        <SectionMarker number="01" label="Co se ptáte" />

        <div class="mt-10 grid gap-10 md:mt-14 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-4">
            <h2
              id="faq"
              class="font-serif text-h2-sm font-medium md:text-h2"
            >
              Na co se nejčastěji ptají.
            </h2>
          </div>
          <div class="md:col-span-8">
            <div class="border-t border-border-subtle">
              {
                faqs.map((faq) => (
                  <details class="faq-item border-b border-border-subtle">
                    <summary class="faq-summary flex cursor-pointer items-start justify-between gap-6 py-6 md:py-8">
                      <span class="font-serif text-h3-sm font-medium text-text-primary md:text-h3">
                        {faq.question}
                      </span>
                      <span
                        class="faq-icon mt-2 shrink-0 font-mono text-body text-text-muted md:mt-3"
                        aria-hidden="true"
                      ></span>
                    </summary>
                    <div class="faq-answer pb-6 md:pb-8">
                      <p
                        class="max-w-prose text-body text-text-secondary"
                        set:html={faq.answer}
                      />
                    </div>
                  </details>
                ))
              }
            </div>
          </div>
        </div>
      </Container>
    </section>

    <section
      class="bg-bg-secondary py-16 md:py-20"
      aria-labelledby="dalsi-krok"
    >
      <Container>
        <h2 id="dalsi-krok" class="sr-only">Další krok</h2>
        <div
          class="flex flex-col gap-5 sm:flex-row sm:items-center sm:gap-8"
        >
          <Button href="/#kontakt" variant="primary">Domluvit konzultaci</Button>
        </div>
      </Container>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .faq-item > summary {
    list-style: none;
  }
  .faq-item > summary::-webkit-details-marker {
    display: none;
  }
  .faq-icon {
    display: inline-block;
    min-width: 1ch;
    text-align: center;
    transition: color 200ms ease;
  }
  .faq-icon::before {
    content: "+";
  }
  .faq-item[open] .faq-icon::before {
    content: "−";
  }
  .faq-answer {
    animation: faq-fade-in 250ms ease-out;
  }
  @media (prefers-reduced-motion: reduce) {
    .faq-icon,
    .faq-answer {
      animation: none;
      transition: none;
    }
  }
  @keyframes faq-fade-in {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .faq-summary:hover .faq-icon {
    color: theme("colors.text.primary");
  }
</style>
