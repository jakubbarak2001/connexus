---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Container from "../../components/Container.astro";
import Button from "../../components/Button.astro";

const title = "marketabarakova.cz · Případová studie | Connexus";
const description =
  "Pojišťovací poradkyně ČSOB Pojišťovny. Seděla v Ústí nad Labem, měla skvělé smlouvy, ale byla limitovaná regionem. Měla 26 000 sledujících na Instagramu, ale téměř žádné konverze.";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "marketabarakova.cz · Případová studie",
  description,
  datePublished: "2026-04-01",
  author: {
    "@type": "Person",
    name: "Jakub Barák",
    url: "https://connexus.cz/#o-mne",
  },
  publisher: {
    "@id": "https://connexus.cz/#connexus",
  },
  image: "https://connexus.cz/images/marketa-screenshot.jpg",
  mainEntityOfPage: "https://connexus.cz/prace/marketa-barakova/",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Úvod",
      item: "https://connexus.cz/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Případová studie",
      item: "https://connexus.cz/prace/marketa-barakova/",
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  ogImage="/images/marketa-hero.jpg"
  ogSquare={null}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(articleSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  </Fragment>
  <Nav />

  <main id="main">
    <Container class="pt-32 md:pt-40">
      <a
        href="/"
        class="inline-flex items-center gap-2 font-mono text-small text-text-muted transition-colors hover:text-text-primary"
      >
        ← Zpět na úvod
      </a>
    </Container>

    <section class="pb-12 pt-10 md:pb-16 md:pt-14">
      <Container>
        <div class="max-w-[900px] space-y-8 md:space-y-10">
          <p class="font-mono text-small text-text-muted">
            <span>Případová studie</span>
            <span class="mx-2 text-border-strong">/</span>
            <span>Finanční poradenství</span>
          </p>

          <div class="flex flex-wrap items-baseline gap-5">
            <h1 class="font-sans text-[40px] font-semibold leading-tight md:text-[56px]">
              marketabarakova.cz
            </h1>
            <span
              class="inline-flex items-center gap-2 font-mono text-small text-accent"
              aria-label="Stav projektu: živě"
            >
              <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
              Živě
            </span>
          </div>

          <p class="max-w-prose text-body-lg text-text-secondary">
            Pojišťovací poradkyně ČSOB Pojišťovny. Seděla v Ústí nad Labem,
            měla skvělé smlouvy, ale
            <strong class="text-text-primary">byla limitovaná regionem</strong>.
          </p>
        </div>
      </Container>
    </section>

    <Container>
      <a
        href="https://marketabarakova.cz"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Otevřít živý web marketabarakova.cz v novém okně"
        class="screenshot-link block"
      >
        <figure
          class="screenshot-frame relative overflow-hidden rounded-soft border border-border-subtle bg-bg-secondary"
        >
          <picture>
            <source srcset="/images/marketa-screenshot.webp" type="image/webp" />
            <img
              src="/images/marketa-screenshot.jpg"
              alt="Celostranný náhled úvodní strany marketabarakova.cz"
              loading="lazy"
              decoding="async"
              class="screenshot-img block h-auto w-full"
            />
          </picture>
          <span class="screenshot-cue" aria-hidden="true">
            Otevřít web
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M7 17L17 7"></path>
              <path d="M8 7h9v9"></path>
            </svg>
          </span>
          <figcaption
            class="border-t border-border-subtle px-6 py-3 font-mono text-small uppercase tracking-[0.08em] text-text-muted md:px-8 md:py-4"
          >
            Ukázka webu
          </figcaption>
        </figure>
      </a>
    </Container>

    <section class="py-20 md:py-28" aria-labelledby="cs-problem">
      <Container>
        <div class="grid gap-10 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-4">
            <h2
              id="cs-problem"
              class="font-mono text-small font-medium uppercase tracking-[0.12em] text-text-secondary"
            >
              <span class="text-accent">01</span>
              <span class="mx-2 text-border-strong" aria-hidden="true">/</span>
              <span>Problém</span>
            </h2>
          </div>
          <div class="max-w-prose space-y-6 md:col-span-8">
            <p class="text-body-lg text-text-primary">
              Měla 26 000 sledujících na Instagramu. <strong>A téměř žádné
                konverze.</strong>
            </p>
            <p class="text-body text-text-secondary">
              Mimo pobočku a pár svých klientů, nikdo o její práci nevěděl.
            </p>
          </div>
        </div>
      </Container>
    </section>

    <section class="bg-bg-secondary py-20 md:py-28" aria-labelledby="cs-pristup">
      <Container>
        <div class="grid gap-10 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-4">
            <h2
              id="cs-pristup"
              class="font-mono text-small font-medium uppercase tracking-[0.12em] text-text-secondary"
            >
              <span class="text-accent">02</span>
              <span class="mx-2 text-border-strong" aria-hidden="true">/</span>
              <span>Přístup</span>
            </h2>
          </div>
          <div class="max-w-prose space-y-6 md:col-span-8">
            <p class="text-body-lg text-text-primary">
              <strong>Začal jsem u značky.</strong> Komu slouží. Čím se liší.
              Proč by vás někdo měl zvolit před kolegyní ze sousední kanceláře.
            </p>
            <p class="text-body text-text-secondary">
              Pak teprve web. Custom design, ne šablona. Texty napsané přímo pro její konkrétní klientelu.
            </p>
            <p class="text-body text-text-secondary">
              Strategie pro sociální sítě a recenze na míru. Podpora s firemním profilem na Googlu. Optimalizace pro vyhledávače.
            </p>
            <p class="text-body text-text-secondary">
              Analytika pro měření každého kroku návštěvníka, plus následné bezplatné úpravy.
            </p>
          </div>
        </div>
      </Container>
    </section>

    <Container>
      <a
        href="https://marketabarakova.cz"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Otevřít živý web marketabarakova.cz v novém okně"
        class="screenshot-link mt-20 block md:mt-28"
      >
        <figure
          class="screenshot-frame relative overflow-hidden rounded-soft border border-border-subtle bg-bg-secondary"
        >
          <picture>
            <source srcset="/images/marketa_below_the_fold.webp" type="image/webp" />
            <img
              src="/images/marketa_below_the_fold.jpg"
              alt="marketabarakova.cz · sekce „Kde začneme?“ s oblastmi pojištění a důvěryhodnostním footerem"
              loading="lazy"
              decoding="async"
              class="screenshot-img block h-auto w-full"
            />
          </picture>
          <span class="screenshot-cue" aria-hidden="true">
            Otevřít web
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M7 17L17 7"></path>
              <path d="M8 7h9v9"></path>
            </svg>
          </span>
          <figcaption
            class="border-t border-border-subtle px-6 py-3 font-mono text-small uppercase tracking-[0.08em] text-text-muted md:px-8 md:py-4"
          >
            Ukázka webu
          </figcaption>
        </figure>
      </a>
    </Container>

    <section class="py-20 md:py-28" aria-labelledby="cs-vysledek">
      <Container>
        <div class="grid gap-10 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-4">
            <h2
              id="cs-vysledek"
              class="font-mono text-small font-medium uppercase tracking-[0.12em] text-text-secondary"
            >
              <span class="text-accent">03</span>
              <span class="mx-2 text-border-strong" aria-hidden="true">/</span>
              <span>Výsledek</span>
            </h2>
          </div>
          <div class="md:col-span-8">
            <blockquote class="border-l-2 border-accent bg-accent-subtle/40 px-6 py-6 md:px-8 md:py-8">
              <p
                class="font-serif text-[24px] font-medium leading-snug text-text-primary md:text-[32px]"
              >
                Měsíc po spuštění ji v jeden den zavolalo
                <strong>přes 30 potenciálních klientů</strong>. Do nedávna byla
                omezena pouze na svou pobočku. Po 6 týdnech uzavírá
                <strong>smlouvy s lidmi z Brna</strong>.
              </p>
            </blockquote>
          </div>
        </div>
      </Container>
    </section>

    <section class="bg-bg-secondary py-20 md:py-28">
      <Container>
        <div class="grid gap-10 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-8 md:col-start-5">
            <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:gap-8">
              <Button href="/#kontakt" variant="primary">Domluvit konzultaci</Button>
              <a
                href="https://marketabarakova.cz"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 font-sans text-small font-medium text-text-primary transition-colors hover:text-accent"
              >
                Otevřít web <span aria-hidden="true">↗</span>
              </a>
            </div>
          </div>
        </div>
      </Container>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .screenshot-link {
    border-radius: theme("borderRadius.soft");
    transition:
      box-shadow 280ms ease,
      transform 280ms ease;
  }
  .screenshot-link:focus-visible {
    outline: 2px solid theme("colors.accent.DEFAULT");
    outline-offset: 6px;
  }

  .screenshot-frame {
    transition:
      border-color 280ms ease,
      box-shadow 280ms ease;
    box-shadow:
      0 30px 90px -30px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.02) inset;
  }
  .screenshot-link:hover .screenshot-frame {
    border-color: theme("colors.border.strong");
    box-shadow:
      0 40px 120px -25px rgba(0, 0, 0, 0.65),
      0 0 80px -20px rgba(255, 122, 69, 0.25),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
  }

  .screenshot-img {
    transition: transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: center top;
  }
  .screenshot-link:hover .screenshot-img {
    transform: scale(1.012);
  }

  .screenshot-cue {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(10, 14, 20, 0.72);
    border: 1px solid rgba(242, 240, 236, 0.14);
    color: theme("colors.text.primary");
    font-family: theme("fontFamily.mono");
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    pointer-events: none;
    transition:
      background-color 220ms ease,
      color 220ms ease,
      border-color 220ms ease,
      transform 220ms ease;
  }
  .screenshot-link:hover .screenshot-cue {
    background-color: theme("colors.accent.DEFAULT");
    border-color: theme("colors.accent.DEFAULT");
    color: theme("colors.bg.primary");
    transform: scale(1.04);
  }
  @media (min-width: 768px) {
    .screenshot-cue {
      top: 18px;
      right: 18px;
      gap: 6px;
      padding: 8px 14px;
      font-size: 12px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .screenshot-link,
    .screenshot-frame,
    .screenshot-img,
    .screenshot-cue {
      transition: none;
    }
    .screenshot-link:hover .screenshot-img {
      transform: none;
    }
    .screenshot-link:hover .screenshot-cue {
      transform: none;
    }
  }
</style>
