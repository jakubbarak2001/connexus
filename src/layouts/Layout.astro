---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  // Square variant for chat-app previews (WhatsApp, iMessage, Signal,
  // Telegram). Pass null to skip emitting the square og:image — useful
  // for sub-pages whose primary image isn't square-friendly.
  ogSquare?: string | null;
}

const {
  title = "Connexus — Weby pro finanční poradce",
  description = "Webové stránky pro pojišťovací poradce, hypoteční makléře a investiční poradce v Česku. Stavím je osobně. Šest měsíců po spuštění optimalizuji na reálných datech.",
  ogImage = "/images/og-default.png",
  ogSquare = "/images/og-square.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const ogSquareUrl = ogSquare ? new URL(ogSquare, Astro.site).href : null;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:site_name" content="Connexus" />

    {/* Landscape (1.91:1) for LinkedIn, Facebook, X, Slack large unfurl */}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    {/* Square (1:1) for WhatsApp, iMessage, Signal, Telegram thumbnails */}
    {ogSquareUrl && (
      <>
        <meta property="og:image" content={ogSquareUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="1200" />
        <meta property="og:image:type" content="image/png" />
      </>
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Non-blocking font loading: preload at high priority, attach as
        non-blocking stylesheet via media trick, then swap to all once
        loaded. Eliminates 780ms render-blocking on critical path.
        FOUT (system font flash) acceptable for premium static site. */}
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400..500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400..500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400..500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap"
      />
    </noscript>

    <slot name="head" />

    {/* Microsoft Clarity — heatmaps + session recordings */}
    <script is:inline>
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "wi7oqxc7qn");
    </script>
  </head>
  <body class="bg-bg-primary text-text-primary antialiased">
    <a href="#main" class="skip-to-main">Přejít na obsah</a>
    <slot />

    <script is:inline>
      (() => {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        const sections = document.querySelectorAll("main > section");
        if (!sections.length) return;

        // Mark sections + fade-ready in one pass (single style invalidation).
        sections.forEach((el) => el.setAttribute("data-fade", ""));
        document.documentElement.classList.add("fade-ready");

        // Use IntersectionObserver for ALL sections — fires synchronously
        // on observe with current intersection state. No manual
        // getBoundingClientRect calls = no forced reflow loop.
        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: "0px 0px -8% 0px" },
        );

        sections.forEach((el) => observer.observe(el));
      })();
    </script>
  </body>
</html>
