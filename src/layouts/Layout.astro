---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  // Square variant for chat-app previews (WhatsApp, iMessage, Signal,
  // Telegram). Pass null to skip emitting the square og:image — useful
  // for sub-pages whose primary image isn't square-friendly.
  ogSquare?: string | null;
}

const {
  title = "Connexus — Weby pro finanční poradce",
  description = "Webové stránky pro pojišťovací poradce, hypoteční makléře a investiční poradce v Česku. Stavím je osobně. Šest měsíců po spuštění optimalizuji na reálných datech.",
  ogImage = "/images/og-default.jpg",
  ogSquare = "/images/og-square.jpg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const ogSquareUrl = ogSquare ? new URL(ogSquare, Astro.site).href : null;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:site_name" content="Connexus" />

    {/* Landscape (1.91:1) for LinkedIn, Facebook, X, Slack large unfurl */}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />

    {/* Square (1:1) for WhatsApp, iMessage, Signal, Telegram thumbnails */}
    {ogSquareUrl && (
      <>
        <meta property="og:image" content={ogSquareUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="1200" />
        <meta property="og:image:type" content="image/jpeg" />
      </>
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400..500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap"
    />

    <slot name="head" />
  </head>
  <body class="bg-bg-primary text-text-primary antialiased">
    <a href="#main" class="skip-to-main">Přejít na obsah</a>
    <slot />

    <script is:inline>
      (() => {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        const sections = document.querySelectorAll("main > section");
        if (!sections.length) return;

        sections.forEach((el) => el.setAttribute("data-fade", ""));
        document.documentElement.classList.add("fade-ready");

        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: "0px 0px -8% 0px" },
        );

        sections.forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.9) {
            el.classList.add("is-visible");
          } else {
            observer.observe(el);
          }
        });
      })();
    </script>
  </body>
</html>
