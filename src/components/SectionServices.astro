---
import Container from "./Container.astro";
import SectionMarker from "./SectionMarker.astro";

const cards = [
  {
    index: "01",
    headline: "Web",
    body: "Vlastní design, texty psané podle vašeho byznysu, SEO a analytika. Žádná šablona, žádná plichta s kolegy z oboru.",
  },
  {
    index: "02",
    headline: "Růst",
    body: "Po spuštění články, optimalizace na reálných datech, péče o Google profil. Aby vás Google začal nacházet, a vy věděli proč.",
  },
  {
    index: "03",
    headline: "Vy",
    body: "Domluvíme se na rozsahu podle toho, kde jste teď. Žádné balíčky, žádná smlouva na rok, žádný výpovědní rituál.",
  },
];
---

<section id="co-delam" class="bg-bg-secondary py-20 md:py-32">
  <Container>
    <SectionMarker number="02" label="Co dělám" />

    <h2
      class="mt-10 max-w-[900px] font-serif text-h2-sm font-medium leading-[1.05] md:mt-14 md:text-h2"
    >
      Webem to <em class="not-italic text-accent">nekončí</em>.<br />Začíná.
    </h2>

    <p class="mt-8 max-w-prose text-body-lg text-text-secondary md:mt-10">
      Spuštěný web sám klienty nepřivede. Práce na něm pokračuje, a já s ní.
    </p>

    <div
      class="mt-14 grid grid-cols-1 gap-10 md:mt-20 md:grid-cols-3 md:gap-12"
    >
      {
        cards.map((card) => (
          <div class="services-card border-t border-border-strong pt-8">
            <p class="font-mono text-small text-accent">{card.index}</p>
            <h3 class="mt-3 font-serif text-h3-sm font-medium text-text-primary md:text-h3">
              {card.headline}
            </h3>
            <p class="mt-4 text-body text-text-secondary">{card.body}</p>
          </div>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .services-card {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .services-card.is-visible {
    opacity: 1;
    transform: none;
  }
  @media (min-width: 768px) {
    .services-card:nth-child(2) {
      transition-delay: 120ms;
    }
    .services-card:nth-child(3) {
      transition-delay: 240ms;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .services-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>(
    "#co-delam .services-card",
  );
  if (cards.length) {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReduced) {
      cards.forEach((card) => card.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.25, rootMargin: "0px 0px -15% 0px" },
      );
      cards.forEach((card) => observer.observe(card));
    }
  }
</script>
