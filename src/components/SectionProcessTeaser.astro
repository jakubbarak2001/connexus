---
import Container from "./Container.astro";
import SectionMarker from "./SectionMarker.astro";

const phases = [
  {
    index: "01",
    title: "Strategie",
    body: "Vstupní rozhovory a strategický dokument. Bez toho nezačínám.",
  },
  {
    index: "02",
    title: "Stavba",
    body: "Čtyři týdny: design, copy, kód, SEO. S vámi v každém kroku.",
  },
  {
    index: "03",
    title: "Spuštění",
    body: "Web jde živě. Dva týdny ho aktivně hlídám.",
  },
  {
    index: "04",
    title: "Péče",
    body: "Šest měsíců v ceně: tři články, optimalizace, revize.",
  },
  {
    index: "05",
    title: "Dál",
    body: "Po šesti měsících si vyberete tarif. Nebo žádný.",
  },
];
---

<section id="proces" class="py-20 md:py-32">
  <Container>
    <SectionMarker number="02" label="Jak to funguje" />

    <h2
      class="mt-10 max-w-[780px] font-serif text-h2-sm font-medium md:mt-14 md:text-h2"
    >
      Postup, který znáte předem.
    </h2>

    <div
      class="process-grid mt-14 grid grid-cols-1 gap-8 md:mt-20 md:grid-cols-5 md:gap-6 lg:gap-8"
    >
      {
        phases.map((phase) => (
          <div class="process-card relative border-t border-border-strong pt-6">
            <p class="font-mono text-small text-accent">{phase.index}</p>
            <h3 class="mt-3 font-sans text-[18px] font-semibold leading-tight text-text-primary md:text-[20px]">
              {phase.title}
            </h3>
            <p class="mt-3 text-small leading-relaxed text-text-secondary md:text-body md:leading-relaxed">
              {phase.body}
            </p>
          </div>
        ))
      }
    </div>

    <div class="mt-14 flex justify-end md:mt-16">
      <a
        href="/jak-to-funguje"
        class="inline-flex items-center gap-2 text-small font-medium text-text-primary transition-colors hover:text-accent"
      >
        Podrobně
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </Container>
</section>

<style>
  .process-card {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .process-card.is-visible {
    opacity: 1;
    transform: none;
  }
  @media (min-width: 768px) {
    .process-card:nth-child(2) {
      transition-delay: 80ms;
    }
    .process-card:nth-child(3) {
      transition-delay: 160ms;
    }
    .process-card:nth-child(4) {
      transition-delay: 240ms;
    }
    .process-card:nth-child(5) {
      transition-delay: 320ms;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .process-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>("#proces .process-card");
  if (cards.length) {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReduced) {
      cards.forEach((card) => card.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2, rootMargin: "0px 0px -10% 0px" },
      );
      cards.forEach((card) => observer.observe(card));
    }
  }
</script>
