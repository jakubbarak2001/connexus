---
import Container from "./Container.astro";
import SectionMarker from "./SectionMarker.astro";

const phases = [
  {
    index: "01",
    title: "Strategie",
    body: "Pochopím váš byznys a klientelu. Z toho vytvořím plán, na kterém stojí všechno další.",
  },
  {
    index: "02",
    title: "Stavba",
    body: "Vlastní design, vlastní kód, vlastní texty a SEO v základu od startu.",
  },
  {
    index: "03",
    title: "Péče",
    body: "Po spuštění zůstanu. Pravidelná péče, ad-hoc zásahy, nebo úplné předání. Prvních 30 dní ladění je v ceně.",
  },
];
---

<section id="proces" class="py-20 md:py-32">
  <Container>
    <SectionMarker number="02" label="Jak to funguje" />

    <h2
      class="mt-10 max-w-[780px] font-serif text-h2-sm font-medium md:mt-14 md:text-h2"
    >
      Tři fáze. <em class="font-medium italic text-accent"
        >Tři až šest týdnů</em
      >.
    </h2>
  </Container>

  <div class="mt-14 md:mt-20">
    {
      phases.map((phase) => (
        <div class="phase-row border-t border-text-primary/25 last:border-b">
          <div class="phase-row__grid mx-auto grid w-full max-w-content grid-cols-1 gap-4 px-6 py-10 md:grid-cols-12 md:items-center md:gap-10 md:px-10 md:py-14">
            <p class="phase-row__num font-mono text-small text-accent-deep md:col-span-1">
              {phase.index}
            </p>
            <h3 class="phase-row__title font-serif font-medium md:col-span-6">
              {phase.title}
            </h3>
            <p class="phase-row__body text-body md:col-span-5">{phase.body}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .phase-row {
    background: transparent;
    transition: background-color 350ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .phase-row__title {
    font-size: clamp(36px, 6vw, 72px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: theme("colors.text.primary");
    transition: color 350ms ease, transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .phase-row__body {
    color: theme("colors.text.secondary");
    transition: color 350ms ease;
    max-width: 420px;
  }
  .phase-row__num {
    transition: color 350ms ease;
  }

  @media (hover: hover) {
    .phase-row:hover {
      background: theme("colors.ink.DEFAULT");
    }
    .phase-row:hover .phase-row__title {
      color: theme("colors.paper.DEFAULT");
      transform: translateX(12px);
    }
    .phase-row:hover .phase-row__body {
      color: theme("colors.ink.mutedtext");
    }
  }

  /* Vstupní odkrytí řádků při scrollu. */
  .phase-row {
    opacity: 0;
    transform: translateY(16px);
    transition:
      background-color 350ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .phase-row.is-visible {
    opacity: 1;
    transform: none;
  }
  /* Stagger jen pro opacity/transform (odkrytí) — background-color musí
     zůstat bez zpoždění, jinak by se loudal hover invert. Pořadí delayů
     odpovídá pořadí vlastností v transition výše. */
  @media (min-width: 768px) {
    .phase-row:nth-child(2) {
      transition-delay: 0ms, 100ms, 100ms;
    }
    .phase-row:nth-child(3) {
      transition-delay: 0ms, 200ms, 200ms;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .phase-row {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const rows = document.querySelectorAll<HTMLElement>("#proces .phase-row");
  if (rows.length) {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReduced) {
      rows.forEach((row) => row.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2, rootMargin: "0px 0px -10% 0px" },
      );
      rows.forEach((row) => observer.observe(row));
    }
  }
</script>
