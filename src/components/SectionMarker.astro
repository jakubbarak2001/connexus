---
interface Props {
  number: string;
  label: string;
  class?: string;
}

const { number, label, class: className = "" } = Astro.props;
---

<p
  class:list={[
    "font-mono text-small font-medium uppercase tracking-[0.12em] text-text-secondary",
    className,
  ]}
>
  <span class="text-accent">{number}</span>
  <span class="mx-2 text-border-strong" aria-hidden="true">/</span>
  <span>{label}</span>
</p>
