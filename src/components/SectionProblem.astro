---
import Container from "./Container.astro";
import SectionMarker from "./SectionMarker.astro";

const cards = [
  {
    index: "01",
    headline: "Nevidí vás.",
    body: "Klient hledá na Googlu. Najde konkurenci - vy jste na straně šest, nebo nikde.",
  },
  {
    index: "02",
    headline: "Tři vteřiny a jsou pryč.",
    body: "Tolik máte na to, aby se web načetl a přesvědčil. Když to nestihne, přišli jste o klienta.",
  },
  {
    index: "03",
    headline: "Nezapamatují si vás.",
    body: "Šablonový web jako tři další. Žádný důvod vybrat si zrovna vás.",
  },
];
---

<section
  id="problem"
  class="relative overflow-hidden bg-bg-secondary py-20 md:py-32"
>
  <div class="problem-grid" aria-hidden="true"></div>
  <div class="relative z-10">
    <Container>
    <SectionMarker number="01" label="Problém" />

    <h2
      class="mt-10 max-w-[900px] font-serif text-h2-sm font-medium md:mt-14 md:text-h2"
    >
      Konkurence není lepší. Je jen víc
      <em class="not-italic text-accent">vidět</em>.
    </h2>

    <p
      class="problem-lead mt-6 max-w-prose text-body text-text-secondary md:mt-8 md:text-body-lg"
    >
      Dnes se rozhoduje na webu - ať už nějaký máte, nebo teprve plánujete.
      Problém není v designu. Je v distribuci.
    </p>

    <div
      class="mt-14 grid grid-cols-1 gap-10 md:mt-20 md:grid-cols-3 md:gap-12"
    >
      {
        cards.map((card) => (
          <div class="problem-card border-t border-border-strong pt-8">
            <span class="problem-card__num" aria-hidden="true">
              {card.index}
            </span>
            <div class="problem-card__inner">
              <p class="font-mono text-small text-accent">{card.index}</p>
              <h3 class="mt-3 font-serif text-h3-sm font-medium text-text-primary md:text-h3">
                {card.headline}
              </h3>
              <p class="mt-4 text-body text-text-secondary">{card.body}</p>
            </div>
          </div>
        ))
      }
    </div>
    </Container>
  </div>
</section>

<style>
  .problem-card,
  .problem-lead {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .problem-card.is-visible,
  .problem-lead.is-visible {
    opacity: 1;
    transform: none;
  }

  .problem-card {
    position: relative;
    transition:
      opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 250ms ease;
  }

  /* Big ghost numeral behind each card — editorial depth. */
  .problem-card__num {
    position: absolute;
    top: 1.75rem;
    right: 0;
    font-family: theme("fontFamily.serif");
    font-size: 120px;
    line-height: 1;
    font-weight: 500;
    color: theme("colors.text.primary");
    opacity: 0.05;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    transition:
      opacity 300ms ease,
      color 300ms ease;
  }

  .problem-card__inner {
    position: relative;
    z-index: 1;
    transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (hover: hover) {
    .problem-card:hover {
      border-color: theme("colors.accent.DEFAULT");
    }
    .problem-card:hover .problem-card__num {
      opacity: 0.1;
      color: theme("colors.accent.DEFAULT");
    }
    .problem-card:hover .problem-card__inner {
      transform: translateY(-4px);
    }
  }

  /* Faint grid texture, matching the hero, to lift the section off flat. */
  .problem-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(theme("colors.border.subtle") 1px, transparent 1px),
      linear-gradient(
        90deg,
        theme("colors.border.subtle") 1px,
        transparent 1px
      );
    background-size: 80px 80px;
    opacity: 0.1;
    mask-image: radial-gradient(ellipse at center, black 15%, transparent 80%);
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 15%,
      transparent 80%
    );
    pointer-events: none;
    z-index: 0;
  }
  /* Stagger only on desktop, where all three cards enter the viewport together.
     On mobile they enter one at a time via scroll, so a transition-delay would
     feel like lag on each individual card. */
  @media (min-width: 768px) {
    .problem-card:nth-child(2) {
      transition-delay: 120ms;
    }
    .problem-card:nth-child(3) {
      transition-delay: 240ms;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .problem-card,
    .problem-lead,
    .problem-card__inner {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>(
    "#problem .problem-lead, #problem .problem-card",
  );
  if (cards.length) {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReduced) {
      cards.forEach((card) => card.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.25, rootMargin: "0px 0px -15% 0px" },
      );
      cards.forEach((card) => observer.observe(card));
    }
  }
</script>
