---
interface Props {
  name?: string;
  role: string;
  lede: string;
  body: string[];
  photo?: string;
  photoAlt: string;
  reverse?: boolean;
}

const { name, role, lede, body, photo, photoAlt, reverse = false } =
  Astro.props;
---

<div class="grid gap-12 md:grid-cols-12 md:gap-16">
  <div
    class:list={[
      "md:col-span-5 lg:col-span-4",
      reverse && "md:col-start-8 lg:col-start-9",
    ]}
  >
    {
      photo ? (
        <div class="person-photo-frame relative md:max-w-[400px]">
          <div class="person-photo-clip">
            <img
              src={photo}
              alt={photoAlt}
              width="400"
              height="400"
              class="block aspect-square w-full object-cover"
            />
            <span class="person-photo-scan" aria-hidden="true" />
          </div>
          <span class="person-photo-corner person-photo-corner--tl" aria-hidden="true" />
          <span class="person-photo-corner person-photo-corner--br" aria-hidden="true" />
        </div>
      ) : (
        <figure
          class="flex aspect-square w-full items-center justify-center border border-border-subtle bg-bg-tertiary md:max-w-[400px]"
          aria-label={`Místo pro fotografii: ${photoAlt}`}
        >
          <span class="font-mono text-small text-text-muted">Fotka</span>
        </figure>
      )
    }
  </div>

  <div
    class:list={[
      "space-y-8 md:col-span-7 md:space-y-10 lg:col-span-7",
      reverse
        ? "md:col-start-1 md:row-start-1 lg:col-start-1"
        : "lg:col-start-6",
    ]}
  >
    <div>
      {
        name && (
          <p class="font-mono text-small uppercase tracking-[0.08em] text-accent">
            {name}
          </p>
        )
      }
      <h2 class="mt-3 font-serif text-h2-sm font-medium md:text-h2">
        {role}
      </h2>
    </div>

    <div class="max-w-prose space-y-6 text-body text-text-secondary">
      <p
        class="text-text-primary"
        style="font-size:22px; font-weight:500; line-height:1.5;"
      >
        {lede}
      </p>
      {body.map((p) => <p set:html={p} />)}
    </div>
  </div>
</div>

<style>
  .person-photo-frame {
    border: 1px solid theme("colors.border.subtle");
    box-shadow: 0 30px 80px -30px rgba(0, 0, 0, 0.6);
  }
  .person-photo-clip {
    position: relative;
    overflow: hidden;
    line-height: 0;
  }
  /* Targeting scan line that sweeps the photo once on lock-on. */
  .person-photo-scan {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 122, 69, 0.9),
      transparent
    );
    box-shadow: 0 0 14px 1px rgba(255, 122, 69, 0.5);
    opacity: 0;
    pointer-events: none;
  }
  .person-photo-corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border: 1.5px solid theme("colors.accent.DEFAULT");
    pointer-events: none;
    opacity: 0;
    transition:
      width 320ms cubic-bezier(0.16, 1, 0.3, 1),
      height 320ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 320ms ease;
  }
  .person-photo-frame.is-locked .person-photo-corner {
    opacity: 1;
  }
  .person-photo-corner--tl {
    top: -1px;
    left: -1px;
    border-right: none;
    border-bottom: none;
  }
  .person-photo-corner--br {
    bottom: -1px;
    right: -1px;
    border-left: none;
    border-top: none;
  }

  /* Lock and loaded: brackets snap in with overshoot, a scan line sweeps
     the photo, then the frame flashes to confirm — plays once on load. */
  @media (prefers-reduced-motion: no-preference) {
    .person-photo-frame.is-locked .person-photo-corner--tl {
      animation: corner-lock-tl 460ms cubic-bezier(0.34, 1.56, 0.64, 1)
        backwards;
    }
    .person-photo-frame.is-locked .person-photo-corner--br {
      animation: corner-lock-br 460ms cubic-bezier(0.34, 1.56, 0.64, 1) 90ms
        backwards;
    }
    .person-photo-frame.is-locked .person-photo-scan {
      animation: photo-scan 720ms cubic-bezier(0.4, 0, 0.2, 1) 150ms 1;
    }
    .person-photo-frame.is-locked {
      animation: frame-confirm 1600ms ease-out 1;
    }
  }

  @media (hover: hover) {
    .person-photo-frame:hover .person-photo-corner {
      width: 28px;
      height: 28px;
    }
  }

  @keyframes corner-lock-tl {
    0% {
      opacity: 0;
      transform: translate(-20px, -20px);
      width: 40px;
      height: 40px;
    }
    60% {
      opacity: 1;
      transform: translate(0, 0);
      width: 18px;
      height: 18px;
      box-shadow: -4px -4px 18px -4px rgba(255, 122, 69, 0.55);
    }
    100% {
      opacity: 1;
      transform: translate(0, 0);
      width: 18px;
      height: 18px;
      box-shadow: 0 0 0 0 rgba(255, 122, 69, 0);
    }
  }
  @keyframes corner-lock-br {
    0% {
      opacity: 0;
      transform: translate(20px, 20px);
      width: 40px;
      height: 40px;
    }
    60% {
      opacity: 1;
      transform: translate(0, 0);
      width: 18px;
      height: 18px;
      box-shadow: 4px 4px 18px -4px rgba(255, 122, 69, 0.55);
    }
    100% {
      opacity: 1;
      transform: translate(0, 0);
      width: 18px;
      height: 18px;
      box-shadow: 0 0 0 0 rgba(255, 122, 69, 0);
    }
  }

  @keyframes photo-scan {
    0% {
      top: 0%;
      opacity: 0;
    }
    15% {
      opacity: 1;
    }
    85% {
      opacity: 1;
    }
    100% {
      top: 100%;
      opacity: 0;
    }
  }

  @keyframes frame-confirm {
    0%,
    45% {
      box-shadow: 0 30px 80px -30px rgba(0, 0, 0, 0.6);
      border-color: theme("colors.border.subtle");
    }
    /* Scan has just finished — the square locks on and holds. */
    58% {
      box-shadow:
        0 30px 80px -30px rgba(0, 0, 0, 0.6),
        0 0 0 2px rgba(255, 122, 69, 0.95),
        0 0 34px 2px rgba(255, 122, 69, 0.5);
      border-color: theme("colors.accent.DEFAULT");
    }
    80% {
      box-shadow:
        0 30px 80px -30px rgba(0, 0, 0, 0.6),
        0 0 0 2px rgba(255, 122, 69, 0.8),
        0 0 30px 1px rgba(255, 122, 69, 0.4);
      border-color: theme("colors.accent.DEFAULT");
    }
    100% {
      box-shadow: 0 30px 80px -30px rgba(0, 0, 0, 0.6);
      border-color: theme("colors.border.subtle");
    }
  }
</style>

<script>
  const frames = document.querySelectorAll<HTMLElement>(".person-photo-frame");
  frames.forEach((frame) => {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-locked");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.35 },
    );
    observer.observe(frame);
  });
</script>
