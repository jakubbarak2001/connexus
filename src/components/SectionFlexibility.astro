---
import Container from "./Container.astro";
---

<section id="vy" class="overflow-hidden bg-accent py-20 text-ink md:py-32">
  <Container>
    <div class="flex-statement max-w-[900px]">
      <p
        class="font-mono text-small font-medium uppercase tracking-[0.12em] text-ink/70"
      >
        ● Podmínky
      </p>
      <h2
        class="mt-8 font-serif font-medium leading-[1.02] text-ink md:mt-10"
        style="font-size: clamp(40px, 7vw, 88px); letter-spacing: -0.03em;"
      >
        Žádné balíčky.<br />Žádné <em class="italic">závazky</em>.
      </h2>
      <p class="mt-8 max-w-prose text-body-lg font-medium text-ink/85 md:mt-10">
        Žádná smlouva na rok, žádný výpovědní rituál. Péči po spuštění si
        určujete vy - pravidelnou, ad-hoc, nebo žádnou.
      </p>
    </div>
  </Container>
</section>

<style>
  .flex-statement {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .flex-statement.is-visible {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .flex-statement {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const el = document.querySelector<HTMLElement>("#vy .flex-statement");
  if (el) {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReduced) {
      el.classList.add("is-visible");
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.3, rootMargin: "0px 0px -10% 0px" },
      );
      observer.observe(el);
    }
  }
</script>
