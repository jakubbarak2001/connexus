---
const navLinks = [
  { href: "/#uvod", label: "Úvod" },
  { href: "/#prace", label: "Práce" },
  { href: "/#o-mne", label: "O mně" },
  { href: "/#kontakt", label: "Kontakt" },
];

const phoneDisplay = "+420 774 563 739";
const phoneHref = "tel:+420774563739";
---

<nav
  id="main-nav"
  class="absolute left-0 right-0 top-0 z-40 transition-[background-color,border-color,backdrop-filter] duration-300 ease-out"
  aria-label="Hlavní navigace"
>
  <div
    class="mx-auto flex max-w-content items-center justify-between gap-6 px-6 py-6 md:px-10"
  >
    <a
      href="/"
      class="font-serif text-[22px] font-medium leading-none tracking-tight text-text-primary"
      aria-label="Connexus — domů"
    >
      Connexus
    </a>

    <ul class="hidden items-center gap-10 md:flex">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-small font-medium text-text-secondary transition-colors duration-200 hover:text-text-primary"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href={phoneHref}
      class="hidden font-mono text-small text-text-secondary transition-colors duration-200 hover:text-accent md:inline-block"
    >
      {phoneDisplay}
    </a>

    <button
      id="nav-toggle"
      type="button"
      class="-mr-1 inline-flex h-10 w-10 items-center justify-center text-text-primary md:hidden"
      aria-label="Otevřít menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="4" y1="8" x2="20" y2="8"></line>
        <line x1="4" y1="16" x2="20" y2="16"></line>
      </svg>
    </button>
  </div>
</nav>

<div
  id="mobile-menu"
  class="fixed inset-0 z-50 hidden flex-col bg-bg-primary md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Menu"
  hidden
>
  <div class="flex items-center justify-between gap-6 px-6 py-6">
    <a
      href="/"
      class="font-serif text-[22px] font-medium leading-none tracking-tight text-text-primary"
      aria-label="Connexus — domů"
      data-mobile-link
    >
      Connexus
    </a>
    <button
      id="nav-close"
      type="button"
      class="-mr-1 inline-flex h-10 w-10 items-center justify-center text-text-primary"
      aria-label="Zavřít menu"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="18" y1="6" x2="6" y2="18"></line>
      </svg>
    </button>
  </div>

  <ul class="flex flex-col gap-2 px-6 pt-10">
    {
      navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block py-3 font-serif text-[32px] font-medium leading-tight text-text-primary"
            data-mobile-link
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="mt-auto flex flex-col gap-2 px-6 pb-12 pt-16">
    <span class="font-mono text-small text-text-muted">Telefon</span>
    <a
      href={phoneHref}
      class="font-sans text-[22px] font-medium text-text-primary"
      data-mobile-link
    >
      {phoneDisplay}
    </a>
  </div>
</div>

<style>
  #main-nav.is-stuck {
    position: fixed;
    background-color: rgb(250 248 245 / 0.92);
    border-bottom: 1px solid theme("colors.border.subtle");
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
  }

  #mobile-menu:not([hidden]) {
    display: flex;
  }
</style>

<script is:inline>
  (() => {
    const nav = document.getElementById("main-nav");
    const toggle = document.getElementById("nav-toggle");
    const closeBtn = document.getElementById("nav-close");
    const menu = document.getElementById("mobile-menu");

    const openMenu = () => {
      if (!menu || !toggle) return;
      menu.removeAttribute("hidden");
      toggle.setAttribute("aria-expanded", "true");
      document.documentElement.style.overflow = "hidden";
    };

    const closeMenu = () => {
      if (!menu || !toggle) return;
      menu.setAttribute("hidden", "");
      toggle.setAttribute("aria-expanded", "false");
      document.documentElement.style.overflow = "";
    };

    toggle?.addEventListener("click", openMenu);
    closeBtn?.addEventListener("click", closeMenu);
    menu?.querySelectorAll("[data-mobile-link]").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu && !menu.hasAttribute("hidden")) closeMenu();
    });

    const updateStuck = () => {
      if (!nav) return;
      const threshold = Math.max(window.innerHeight * 0.7, 480);
      nav.classList.toggle("is-stuck", window.scrollY > threshold);
    };
    window.addEventListener("scroll", updateStuck, { passive: true });
    window.addEventListener("resize", updateStuck);
    updateStuck();
  })();
</script>
