---
import Container from "./Container.astro";
---

<section class="bridge relative overflow-hidden bg-bg-tertiary py-24 md:py-36">
  <div class="bridge__glow" aria-hidden="true"></div>
  <Container class="relative">
    <div class="bridge__copy max-w-[900px] space-y-6 md:space-y-8">
      <p
        class="bridge__eyebrow font-mono text-small uppercase tracking-[0.12em] text-accent"
      >
        Co je možné
      </p>
      <h2 class="bridge__statement font-serif font-medium text-text-primary">
        Sedí v Ústí.<br />Volá jí <em class="text-accent not-italic">Brno</em>.
      </h2>
      <p class="bridge__caption max-w-prose text-body-lg text-text-secondary">
        Šest týdnů. A region přestal být strop.
      </p>
    </div>

    <a
      href="/prace/marketa-barakova"
      aria-label="Zobrazit případovou studii: marketabarakova.cz"
      class="bridge__frame-link block"
    >
      <figure class="bridge__frame mt-14 md:mt-20">
        <div class="browser-chrome">
          <span class="browser-chrome__dot browser-chrome__dot--red"></span>
          <span class="browser-chrome__dot browser-chrome__dot--yellow"></span>
          <span class="browser-chrome__dot browser-chrome__dot--green"></span>
          <span class="browser-chrome__url">marketabarakova.cz</span>
        </div>
        <span class="bridge__cue" aria-hidden="true">
          Otevřít studii
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.4"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M7 17L17 7" />
            <path d="M8 7h9v9" />
          </svg>
        </span>
        <picture>
          <source srcset="/images/marketa-hero.webp" type="image/webp" />
          <img
            src="/images/marketa-hero.jpg"
            alt="Hero sekce webu marketabarakova.cz — pojišťovací poradkyně Markéta Baráková"
            width="1920"
            height="765"
            loading="lazy"
            decoding="async"
            class="bridge__img block h-auto w-full"
          />
        </picture>
      </figure>
    </a>

    <p class="bridge__live-link mt-6 flex justify-end md:mt-8">
      <a
        href="https://marketabarakova.cz"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-mono text-small uppercase tracking-[0.08em] text-text-secondary transition-colors hover:text-accent"
      >
        Otevřít živý web
        <span aria-hidden="true">↗</span>
      </a>
    </p>
  </Container>
</section>

<style>
  .bridge__statement {
    font-size: clamp(40px, 8vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }
  @media (min-width: 768px) {
    .bridge__statement {
      font-size: clamp(56px, 6vw, 96px);
    }
  }

  .bridge__glow {
    position: absolute;
    top: 30%;
    left: 50%;
    width: min(900px, 90vw);
    height: 600px;
    transform: translate(-50%, -10%);
    background: radial-gradient(
      ellipse at center,
      rgba(255, 122, 69, 0.18) 0%,
      rgba(255, 122, 69, 0.06) 35%,
      transparent 70%
    );
    pointer-events: none;
    filter: blur(40px);
    z-index: 0;
  }

  .bridge__frame {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    background: theme("colors.chrome.frame");
    border: 1px solid theme("colors.border.subtle");
    box-shadow:
      0 40px 120px -30px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.02) inset;
    margin: 56px 0 0 0;
  }

  .bridge__frame-link {
    border-radius: 14px;
    transition:
      box-shadow 280ms ease,
      transform 280ms ease;
  }
  .bridge__frame-link:hover .bridge__frame {
    border-color: theme("colors.border.strong");
    box-shadow:
      0 50px 140px -25px rgba(0, 0, 0, 0.75),
      0 0 80px -20px rgba(255, 122, 69, 0.25),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
  }
  .bridge__frame-link:focus-visible {
    outline: 2px solid theme("colors.accent.DEFAULT");
    outline-offset: 6px;
  }

  .bridge__img {
    transition: transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: center top;
  }
  .bridge__frame-link:hover .bridge__img {
    transform: scale(1.012);
  }

  .bridge__cue {
    position: absolute;
    bottom: 12px;
    right: 12px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(10, 14, 20, 0.72);
    border: 1px solid rgba(242, 240, 236, 0.14);
    color: theme("colors.text.primary");
    font-family: theme("fontFamily.mono");
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    pointer-events: none;
    transition:
      background-color 220ms ease,
      color 220ms ease,
      border-color 220ms ease,
      transform 220ms ease;
  }
  .bridge__frame-link:hover .bridge__cue {
    background-color: theme("colors.accent.DEFAULT");
    border-color: theme("colors.accent.DEFAULT");
    color: theme("colors.bg.primary");
    transform: scale(1.04);
  }
  @media (min-width: 768px) {
    .bridge__cue {
      bottom: 18px;
      right: 18px;
      gap: 6px;
      padding: 8px 14px;
      font-size: 12px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .bridge__img,
    .bridge__cue {
      transition: none;
    }
    .bridge__frame-link:hover .bridge__img {
      transform: none;
    }
    .bridge__frame-link:hover .bridge__cue {
      transform: none;
    }
  }
  @media (min-width: 768px) {
    .bridge__frame {
      margin-top: 80px;
    }
  }

  .browser-chrome {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: theme("colors.chrome.bar");
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .browser-chrome__dot {
    width: 11px;
    height: 11px;
    border-radius: 999px;
    display: inline-block;
  }
  .browser-chrome__dot--red {
    background: #ff5f57;
  }
  .browser-chrome__dot--yellow {
    background: #febc2e;
  }
  .browser-chrome__dot--green {
    background: #28c840;
  }
  .browser-chrome__url {
    margin-left: 12px;
    padding: 4px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.7);
    font-family: theme("fontFamily.mono");
    font-size: 12px;
    letter-spacing: 0.02em;
  }
  @media (min-width: 768px) {
    .browser-chrome {
      padding: 14px 20px;
    }
    .browser-chrome__url {
      margin-left: 20px;
      font-size: 13px;
    }
  }

  .bridge__copy,
  .bridge__frame {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 280ms ease,
      box-shadow 280ms ease;
    will-change: opacity, transform;
  }
  .bridge__frame {
    transition-delay: 160ms;
  }
  .bridge__copy.is-visible,
  .bridge__frame.is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .bridge__copy,
    .bridge__frame {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const targets = document.querySelectorAll<HTMLElement>(
    ".bridge__copy, .bridge__frame",
  );
  if (targets.length) {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReduced) {
      targets.forEach((el) => el.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2, rootMargin: "0px 0px -10% 0px" },
      );
      targets.forEach((el) => observer.observe(el));
    }
  }
</script>
