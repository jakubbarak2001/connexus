---
import Container from "./Container.astro";
import SectionMarker from "./SectionMarker.astro";
import PersonBlock from "./PersonBlock.astro";
---

<section id="o-mne" class="py-20 md:py-32">
  <Container>
    <div class="space-y-14 md:space-y-20">
      <SectionMarker number="04" label="O mně" />

      <PersonBlock
        role="Vývojář, stratég a autor textů"
        lede="Jmenuji se Jakub Barák."
        body={[
          "Stavím weby pro lidi, kteří se živí tím, že jsou vidět. Než začnu psát kód, sednu si s vámi a chci rozumět vašemu byznysu — čím se odlišujete od kolegů, kdo jsou vaši klienti, jak prodáváte. Web bez tohohle kontextu je jen design.",
          "<strong>Po spuštění nezmizím.</strong> Šest měsíců projekt sleduji, ladím na reálných datech a každý zásah obhájím čísly, ne dojmem.",
        ]}
        photo="/images/jakub_foto.jpg"
        photoAlt="Jakub Barák — zakladatel Connexus"
      />
    </div>
  </Container>
</section>
