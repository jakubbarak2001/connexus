---
import Container from "./Container.astro";
import SectionMarker from "./SectionMarker.astro";
import PersonBlock from "./PersonBlock.astro";
---

<section id="o-mne" class="py-20 md:py-32">
  <Container>
    <div class="space-y-14 md:space-y-20">
      <SectionMarker number="03" label="O mně" />

      <PersonBlock
        name="Jakub Barák - zakladatel Connexus"
        role="Stavím weby pro lidi, kteří se živí tím, že jsou vidět."
        body={[
          "Než začnu psát kód, sednu si s vámi a chci rozumět vašemu byznysu. Čím se odlišujete od kolegů, kdo jsou vaši klienti, jak prodáváte. Web bez tohoto kontextu je jen design.",
        ]}
        photo="/images/jakub_foto.jpg"
        photoAlt="Jakub Barák, zakladatel Connexus"
      />
    </div>
  </Container>
</section>
