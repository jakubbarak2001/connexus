---
import Container from "./Container.astro";
import SectionMarker from "./SectionMarker.astro";
import PersonBlock from "./PersonBlock.astro";
---

<section id="o-mne" class="py-20 md:py-32">
  <Container>
    <div class="space-y-14 md:space-y-20">
      <SectionMarker number="05" label="O mně" />

      <PersonBlock
        role="Vývojář, který přemýšlí jako podnikatel."
        lede="Jmenuji se Jakub Barák."
        body={[
          "Stavím weby pro lidi, kteří se živí tím, že jsou vidět. Než začnu psát kód, sednu si s vámi a chci rozumět vašemu byznysu. Čím se odlišujete od kolegů, kdo jsou vaši klienti, jak prodáváte. Web bez tohoto kontextu je jen design.",
          "<strong>Po spuštění nezmizím.</strong> Pravidelná péče, ad-hoc zásahy bez závazku, nebo úplné předání. Rozsah si vybíráte vy. Každý zásah chci obhájit čísly, ne dojmem.",
        ]}
        photo="/images/jakub_foto.jpg"
        photoAlt="Jakub Barák, zakladatel Connexus"
      />
    </div>
  </Container>
</section>
