---
import Container from "./Container.astro";
import SectionMarker from "./SectionMarker.astro";
import Button from "./Button.astro";

interface Slot {
  number: string;
  status: "obsazeno" | "volné";
  name?: string;
  meta?: string;
  url?: string;
}

const FOUNDING_PRICE_DISPLAY = "35 000";
const STANDARD_PRICE_DISPLAY = "60 000";

const slots: Slot[] = [
  {
    number: "01",
    status: "obsazeno",
    name: "Markéta Baráková",
    meta: "Pojišťovací poradkyně · uzavřeno 03/2026",
    url: "https://marketabarakova.cz",
  },
  {
    number: "02",
    status: "volné",
  },
  {
    number: "03",
    status: "volné",
  },
];
---

<section id="zakladajici" class="bg-bg-secondary py-20 md:py-32">
  <Container>
    <SectionMarker number="03" label="Zakládající klienti" />

    <div class="mt-10 max-w-[900px] md:mt-14">
      <h2 class="font-serif text-h2-sm font-medium leading-[1.05] md:text-h2">
        Tři zakládající klienti.<br />
        <em class="not-italic text-accent">Zaváděcí podmínky 2026.</em>
      </h2>
    </div>

    <p
      class="mt-10 font-mono text-small uppercase tracking-[0.08em] text-text-muted md:mt-14"
    >
      Zaváděcí cena · platná do naplnění tří míst
    </p>

    <ol class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-6">
      {
        slots.map((slot) => (
          <li
            class:list={[
              "founding-card relative flex flex-col gap-5 border p-6 md:p-7",
              slot.status === "obsazeno"
                ? "border-accent/30 bg-bg-elevated"
                : "border-border-strong bg-bg-tertiary",
            ]}
          >
            <div class="flex items-center justify-between">
              <span class="font-mono text-small text-text-muted">
                {slot.number}
              </span>
              {slot.status === "obsazeno" ? (
                <span class="inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-[0.1em] text-accent">
                  <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true" />
                  Obsazeno
                </span>
              ) : (
                <span class="inline-flex items-center gap-1.5 font-mono text-[11px] uppercase tracking-[0.1em] text-text-muted">
                  <span
                    class="h-1.5 w-1.5 rounded-full border border-border-strong"
                    aria-hidden="true"
                  />
                  Volné
                </span>
              )}
            </div>

            {slot.status === "obsazeno" ? (
              <Fragment>
                <div class="space-y-2">
                  <p class="font-serif text-h3-sm font-medium text-text-primary md:text-h3">
                    {slot.url ? (
                      <a
                        href={slot.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`Otevřít ${slot.url.replace(/^https?:\/\//, "")} v novém okně`}
                        class="founding-link"
                      >
                        {slot.name}
                      </a>
                    ) : (
                      slot.name
                    )}
                  </p>
                  <p class="font-mono text-small text-text-muted">
                    {slot.meta}
                  </p>
                </div>
              </Fragment>
            ) : (
              <Fragment>
                <div class="space-y-2">
                  <p class="font-serif text-h3-sm font-medium text-text-primary md:text-h3">
                    — Volné místo —
                  </p>
                  <p class="font-mono text-small text-text-muted">
                    K dispozici pro zakládajícího klienta
                  </p>
                </div>
                <div class="mt-auto flex items-baseline gap-3 border-t border-border-subtle pt-5">
                  <p class="font-serif text-h3 font-medium text-text-primary md:text-[32px]">
                    {FOUNDING_PRICE_DISPLAY} Kč
                  </p>
                  <p class="font-mono text-small text-text-muted line-through">
                    {STANDARD_PRICE_DISPLAY} Kč
                  </p>
                </div>
              </Fragment>
            )}
          </li>
        ))
      }
    </ol>

    <div class="mt-12 grid gap-10 md:mt-16 md:grid-cols-12 md:gap-16">
      <div class="md:col-span-7">
        <div class="max-w-prose space-y-6 text-body text-text-secondary">
          <p>
            Zaváděcí cena platí pro první tři spolupráce — výměnou za to, že
            jdete do projektu se studiem, které teprve sbírá portfolio. Místo
            dlouhé reference dostanete šest měsíců péče v základu, prioritní
            dostupnost a víc mého času, než budu schopen dát klientům později.
          </p>
          <p>
            Cílem je, aby z těch tří projektů vznikly případovky, na kterých
            chci stavět dál. Když do toho půjdete se mnou, máme společný zájem
            na tom, aby výsledek opravdu fungoval.
          </p>
        </div>
      </div>

      <div class="md:col-span-5">
        <p class="font-mono text-small uppercase tracking-[0.08em] text-text-muted">
          Co dostanete
        </p>
        <ul class="mt-4 space-y-2 text-body text-text-secondary">
          <li>Šest měsíců péče po spuštění</li>
          <li>Prioritní dostupnost a přímý kontakt</li>
          <li>Strategický check-in v měsíci 4</li>
          <li>Závěrečná revize v měsíci 6</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 md:mt-16">
      <Button href="#kontakt" variant="primary">Domluvit konzultaci</Button>
    </div>
  </Container>
</section>

<style>
  .founding-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: rgba(255, 122, 69, 0.45);
    text-decoration-thickness: 1px;
    text-underline-offset: 6px;
    transition:
      color 220ms ease,
      text-decoration-color 220ms ease,
      text-decoration-thickness 220ms ease;
  }
  .founding-link:hover,
  .founding-link:focus-visible {
    color: theme("colors.accent.DEFAULT");
    text-decoration-color: theme("colors.accent.DEFAULT");
    text-decoration-thickness: 2px;
  }
  .founding-link:focus-visible {
    outline: 2px solid theme("colors.accent.DEFAULT");
    outline-offset: 4px;
    border-radius: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .founding-link {
      transition: none;
    }
  }
</style>
