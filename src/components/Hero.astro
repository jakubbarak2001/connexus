---
import Button from "./Button.astro";

const occupations = [
  "Pojišťovací poradce",
  "Hypoteční makléře",
  "Investiční poradce",
];
---

<section
  id="uvod"
  class="hero relative flex items-center overflow-hidden px-6 md:px-12 lg:px-20"
>
  <div class="hero__backdrop" aria-hidden="true"></div>
  <div class="hero__grid" aria-hidden="true"></div>

  <div class="relative mx-auto w-full max-w-6xl">
    <p class="hero__eyebrow font-mono uppercase text-accent">
      <span class="sr-only"
        >Pro pojišťovací poradce, hypoteční makléře a investiční poradce.</span
      >
      <span aria-hidden="true">
        Pro <span class="hero__rotator" data-rotator>
          {
            occupations.map((label, i) => (
              <span
                class:list={[
                  "hero__rotator-word",
                  i === 0 && "is-active",
                  i === 0 && "is-first",
                ]}
              >
                {label}
              </span>
            ))
          }
        </span>
      </span>
    </p>

    <h1 class="hero__h1 font-serif font-medium text-text-primary">
      Zasloužíte si <em class="hero__accent-word">víc</em> než jen běžný web.
    </h1>

    <p class="hero__subhead text-text-secondary">
      Web je jen začátek. Píšu texty, ze kterých vás Google zviditelní, radím
      s recenzemi a sociálními sítěmi, <strong class="text-text-primary"
        >rozumím vašemu byznysu</strong
      > — a šest měsíců po spuštění optimalizuji na reálných datech.
    </p>

    <div class="hero__ctas">
      <Button href="#kontakt" variant="primary">Domluvit konzultaci</Button>
      <a
        href="/prace/marketa-barakova"
        class="hero__secondary-link font-mono text-small uppercase tracking-[0.08em]"
      >
        Vidět práci pro Markétu
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="hero__trust-strip" aria-label="Stav zakládajících míst">
      <span class="hero__trust-dot" aria-hidden="true"></span>
      <span class="hero__trust-text">
        <strong>01 / 03</strong> zakládajících klientů obsazeno · zaváděcí cena
        platí do naplnění
      </span>
    </div>
  </div>

  <a
    href="#problem"
    class="hero__chevron text-text-secondary"
    aria-label="Přejít na další sekci"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M6 9l6 6 6-6"></path>
    </svg>
  </a>
</section>

<style>
  .hero {
    min-height: 85vh;
  }

  .hero__backdrop {
    position: absolute;
    top: -10%;
    right: -10%;
    width: 70%;
    height: 90%;
    background: radial-gradient(
      ellipse at top right,
      rgba(255, 122, 69, 0.18) 0%,
      rgba(255, 122, 69, 0.05) 30%,
      transparent 60%
    );
    pointer-events: none;
    filter: blur(60px);
    z-index: 0;
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(theme("colors.border.subtle") 1px, transparent 1px),
      linear-gradient(90deg, theme("colors.border.subtle") 1px, transparent 1px);
    background-size: 80px 80px;
    background-position: -1px -1px;
    opacity: 0.18;
    mask-image: radial-gradient(
      ellipse at center,
      black 30%,
      transparent 75%
    );
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 30%,
      transparent 75%
    );
    pointer-events: none;
    z-index: 0;
  }

  .hero__eyebrow {
    font-size: 13px;
    letter-spacing: 0.08em;
    margin-bottom: 24px;
  }

  .hero__h1 {
    font-size: clamp(44px, 11vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  .hero__accent-word {
    color: theme("colors.accent.DEFAULT");
    font-style: italic;
    font-weight: 500;
  }

  .hero__subhead {
    font-size: 18px;
    line-height: 1.5;
    max-width: 600px;
    margin-top: 32px;
  }

  .hero__ctas {
    margin-top: 48px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
  }

  .hero__secondary-link {
    color: theme("colors.text.secondary");
    transition: color 200ms ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hero__secondary-link:hover {
    color: theme("colors.accent.DEFAULT");
  }
  .hero__secondary-link span {
    transition: transform 200ms ease;
  }
  .hero__secondary-link:hover span {
    transform: translateX(3px);
  }

  .hero__trust-strip {
    margin-top: 56px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    border: 1px solid theme("colors.border.subtle");
    border-radius: 999px;
    background: rgba(20, 25, 35, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .hero__trust-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: theme("colors.accent.DEFAULT");
    box-shadow: 0 0 12px theme("colors.accent.DEFAULT");
    animation: trust-pulse 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }
  .hero__trust-text {
    font-family: theme("fontFamily.mono");
    font-size: 12px;
    color: theme("colors.text.secondary");
    letter-spacing: 0.02em;
  }
  .hero__trust-text strong {
    color: theme("colors.text.primary");
    font-weight: 500;
  }
  @keyframes trust-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 12px theme("colors.accent.DEFAULT"); }
    50% { opacity: 0.6; box-shadow: 0 0 4px theme("colors.accent.DEFAULT"); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__trust-dot {
      animation: none;
    }
  }

  @media (min-width: 768px) {
    .hero {
      min-height: 90vh;
    }

    .hero__eyebrow {
      font-size: 14px;
    }

    .hero__h1 {
      font-size: clamp(80px, 9vw, 132px);
    }

    .hero__subhead {
      font-size: 22px;
    }

    .hero__trust-text {
      font-size: 13px;
    }
  }

  .hero__chevron {
    position: absolute;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    color: inherit;
    transition: color 200ms ease;
  }
  .hero__chevron:hover {
    color: theme("colors.text.primary");
  }
  @media (min-width: 768px) {
    .hero__chevron {
      bottom: 40px;
    }
  }

  /* ===== Rotating eyebrow occupation =====
     Underline is statically visible from page load (a quiet anchor).
     Cycling begins after a short delay so the H1 has reading time first. */

  .hero__rotator {
    display: inline-grid;
    grid-template-columns: 1fr;
    vertical-align: baseline;
  }

  .hero__rotator-word {
    grid-column: 1;
    grid-row: 1;
    justify-self: start;
    position: relative;
    opacity: 0;
    transform: translateY(8px);
    white-space: nowrap;
  }

  .hero__rotator-word.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  .hero__rotator-word::after {
    content: "";
    position: absolute;
    left: -0.15em;
    right: -0.15em;
    bottom: -3px;
    height: 1.5px;
    background: theme("colors.accent.DEFAULT");
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
  }

  .hero__rotator[data-rotator-init]:not([data-rotator-cycling])
    .hero__rotator-word.is-active::after {
    opacity: 1;
    transform: translateY(0);
  }

  .hero__rotator[data-rotator-cycling]
    .hero__rotator-word.is-active.is-first {
    animation: rotator-word-first 1500ms ease-in-out forwards;
  }

  .hero__rotator[data-rotator-cycling]
    .hero__rotator-word.is-active:not(.is-first) {
    animation: rotator-word 2500ms ease-in-out forwards;
  }

  .hero__rotator[data-rotator-cycling]
    .hero__rotator-word.is-active.is-first::after {
    animation: rotator-underline-first 1500ms ease-in-out forwards;
  }

  .hero__rotator[data-rotator-cycling]
    .hero__rotator-word.is-active:not(.is-first)::after {
    animation: rotator-underline 2500ms ease-in-out forwards;
  }

  @keyframes rotator-word {
    0% { opacity: 0; transform: translateY(10px); }
    12% { opacity: 1; transform: translateY(0); }
    84% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-10px); }
  }

  @keyframes rotator-word-first {
    0% { opacity: 1; transform: translateY(0); }
    84% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-10px); }
  }

  @keyframes rotator-underline {
    0% { opacity: 0; transform: translateY(8px); }
    15% { opacity: 0; transform: translateY(8px); }
    26% { opacity: 1; transform: translateY(0); }
    72% { opacity: 1; transform: translateY(0); }
    80% { opacity: 0; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(0); }
  }

  @keyframes rotator-underline-first {
    0% { opacity: 1; transform: translateY(0); }
    72% { opacity: 1; transform: translateY(0); }
    80% { opacity: 0; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__rotator .hero__rotator-word.is-active,
    .hero__rotator .hero__rotator-word.is-active::after,
    .hero__rotator .hero__rotator-word.is-active.is-first {
      animation: none;
    }
    .hero__rotator-word.is-active {
      opacity: 1;
      transform: none;
    }
    .hero__rotator-word.is-active::after {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Eyebrow rotator — cycles through professions. Hero content is fully
  // visible on first paint (no entry animations) for fastest LCP. The
  // rotator's underline is statically visible from page load; the word
  // cycling waits 1500ms so the reader's first beat lands on the H1.
  const rotator = document.querySelector<HTMLElement>(
    ".hero__rotator[data-rotator]",
  );

  if (rotator) {
    const words = rotator.querySelectorAll<HTMLElement>(".hero__rotator-word");
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (!prefersReduced && words.length) {
      rotator.setAttribute("data-rotator-init", "");

      const FIRST_INTERVAL = 1500;
      const INTERVAL_MS = 2500;

      const transition = () => {
        const current = Array.from(words).find((w) =>
          w.classList.contains("is-active"),
        );
        if (!current) return;
        const currentIndex = Array.from(words).indexOf(current);
        const nextIndex = (currentIndex + 1) % words.length;
        current.classList.remove("is-active");
        current.classList.remove("is-first");
        words[nextIndex].classList.add("is-active");
      };

      window.setTimeout(() => {
        rotator.setAttribute("data-rotator-cycling", "");
        transition();
        window.setInterval(transition, INTERVAL_MS);
      }, FIRST_INTERVAL);
    } else if (prefersReduced) {
      rotator.setAttribute("data-rotator-init", "");
    }
  }
</script>
