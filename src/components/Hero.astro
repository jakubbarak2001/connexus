---
import Button from "./Button.astro";
---

<section id="uvod" class="hero flex items-center px-6 md:px-12 lg:px-20">
  <div class="mx-auto w-full max-w-6xl">
    <p class="hero__eyebrow font-mono uppercase text-accent">Pro finanční poradce</p>

    <h1 class="hero__h1 font-serif font-medium text-text-primary">
      Váš web by neměl vypadat jako tisíc dalších.
    </h1>

    <p class="hero__subhead text-text-secondary">
      Custom design, copy psaný člověkem, dlouhodobá péče.
    </p>

    <div class="hero__ctas flex flex-col items-start gap-6 sm:flex-row sm:items-center">
      <Button href="#kontakt" variant="primary">Domluvit konzultaci</Button>
      <Button href="/prace/marketa-barakova" variant="link">Zobrazit případovou studii</Button>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 85vh;
  }

  .hero__eyebrow {
    font-size: 13px;
    letter-spacing: 0.08em;
    margin-bottom: 24px;
  }

  .hero__h1 {
    font-size: clamp(40px, 10vw, 64px);
    line-height: 0.95;
    letter-spacing: -0.03em;
  }

  .hero__subhead {
    font-size: 18px;
    line-height: 1.5;
    max-width: 540px;
    margin-top: 32px;
  }

  .hero__ctas {
    margin-top: 48px;
  }

  @media (min-width: 768px) {
    .hero {
      min-height: 90vh;
    }

    .hero__eyebrow {
      font-size: 14px;
    }

    .hero__h1 {
      font-size: clamp(80px, 8vw, 140px);
    }

    .hero__subhead {
      font-size: 22px;
    }
  }
</style>
